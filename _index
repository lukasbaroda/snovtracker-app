<!DOCTYPE html>
<html lang="lt">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Snovtracker — sek geriausius Solana treiderius</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='7' fill='%236c8cff'/><g stroke='white' stroke-width='2.2' stroke-linecap='round'><line x1='16' y1='5' x2='16' y2='27'/><line x1='6.7' y1='10.5' x2='25.3' y2='21.5'/><line x1='6.7' y1='21.5' x2='25.3' y2='10.5'/></g></svg>" />
<style>
  :root{ --bg:#080b12; --card:#10151f; --card2:#141b28; --line:#1e2738; --line2:#2a3650; --text:#eef2f8; --mut:#7e89a0; --grn:#1ed7a0; --red:#f0556b; --gold:#ffcf5c; --acc:#6c8cff; }
  *{box-sizing:border-box}
  body{margin:0;background:radial-gradient(1200px 600px at 70% -10%,#15203a 0%,var(--bg) 55%);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;-webkit-font-smoothing:antialiased}
  .wrap{max-width:1000px;margin:0 auto;padding:30px 20px 80px}
  .brand{font-size:25px;font-weight:800;letter-spacing:-.4px}.brand span{background:linear-gradient(90deg,#6c8cff,#1ed7a0);-webkit-background-clip:text;background-clip:text;color:transparent}
  .tag{color:var(--mut);font-size:14px;margin:5px 0 22px}
  .pos{color:var(--grn)} .neg{color:var(--red)} .mut{color:var(--mut)}
  .addr{font-family:ui-monospace,monospace}
  .asset{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.5px;color:var(--mut);border:1px solid var(--line2);border-radius:6px;padding:1px 6px;margin-left:5px}
  .statbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px}
  .sc{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:8px 14px;min-width:96px}
  .sc .n{font-size:19px;font-weight:800;letter-spacing:-.5px}
  .sc .l{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.4px}
  .controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:18px}
  .pill{background:var(--card);border:1px solid var(--line);color:var(--text);padding:7px 14px;border-radius:999px;cursor:pointer;font-size:13px}
  .pill.on{background:linear-gradient(90deg,#6c8cff,#5a78f0);border-color:transparent;color:#fff;font-weight:600}
  .spacer{flex:1}
  select{background:var(--card);border:1px solid var(--line);color:var(--text);padding:8px 12px;border-radius:9px;font-size:13px}
  /* sleek rows */
  .rows{display:flex;flex-direction:column;gap:10px}
  .row{display:grid;grid-template-columns:40px 1fr 120px 120px 120px;align-items:center;gap:14px;background:var(--card);border:1px solid var(--line);border-radius:16px;padding:14px 18px;transition:.16s;cursor:pointer}
  .row:hover{border-color:var(--line2);transform:translateY(-2px);box-shadow:0 12px 30px -14px rgba(108,140,255,.3)}
  .rk{font-size:18px;font-weight:800;color:var(--mut);text-align:center}
  .row.top1 .rk{background:linear-gradient(180deg,#ffe89a,#ffb347);-webkit-background-clip:text;background-clip:text;color:transparent}
  .who .nm{font-weight:600;font-size:15px}
  .who .sub{font-size:12px;color:var(--mut);margin-top:2px}
  .spark{height:36px;width:120px}
  .mini{display:flex;gap:16px;justify-content:flex-end}
  .mini .l{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.4px}
  .mini .v{font-size:14px;font-weight:600;margin-top:1px}
  .ret{font-size:22px;font-weight:800;letter-spacing:-.5px;text-align:right}
  .row .pnl{text-align:right;font-size:12px;color:var(--mut)}
  .more{display:block;margin:24px auto 0;background:var(--card);border:1px solid var(--line2);color:var(--text);padding:10px 24px;border-radius:10px;cursor:pointer;font-size:14px}
  @media(max-width:680px){.row{grid-template-columns:32px 1fr 90px}.spark,.mini{display:none}}
  /* modal */
  .ov{position:fixed;inset:0;background:rgba(4,7,12,.7);display:none;align-items:flex-start;justify-content:center;padding:18px;z-index:50;overflow:auto;backdrop-filter:blur(3px)}
  .ov.on{display:flex}
  .modal{background:var(--card);border:1px solid var(--line2);border-radius:18px;max-width:820px;width:100%;padding:22px;margin:auto}
  .x{float:right;cursor:pointer;color:var(--mut);font-size:22px;line-height:1}
  .cta{background:linear-gradient(90deg,#6c8cff,#5a78f0);border:none;color:#fff;font-weight:600;padding:11px;border-radius:11px;cursor:pointer;font-size:14px}
  .cta.sec{background:var(--card2);color:var(--text);border:1px solid var(--line2)}
  .seg{display:inline-flex;background:var(--card2);border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .seg button{background:none;border:none;color:var(--mut);padding:7px 13px;cursor:pointer;font-size:13px}
  .seg button.on{background:var(--acc);color:#fff;font-weight:600}
  .amtbox{display:flex;align-items:center;gap:10px;flex-wrap:wrap;background:var(--card2);border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin:14px 0}
  .amtbox input{background:#0c111b;border:1px solid var(--line2);color:var(--text);padding:9px 12px;border-radius:9px;font-size:16px;width:130px}
  .kpis{display:flex;gap:10px;flex-wrap:wrap;margin:8px 0}
  .kpi{background:var(--card2);border:1px solid var(--line);border-radius:10px;padding:9px 13px}
  .kpi .l{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.4px}
  .kpi .v{font-size:15px;font-weight:700;margin-top:2px}
  table{width:100%;border-collapse:collapse;font-size:13px;margin-top:8px}
  th,td{text-align:left;padding:7px 8px;border-bottom:1px solid var(--line)}
  th{color:var(--mut);font-weight:600;font-size:11px;text-transform:uppercase}
  h3{font-size:12px;text-transform:uppercase;letter-spacing:.6px;color:var(--mut);margin:20px 0 6px}
  .pgbtn{background:var(--card2);border:1px solid var(--line2);color:var(--text);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:12px}
  .pgbtn:disabled{opacity:.4;cursor:default}
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--grn);color:#04140c;padding:10px 18px;border-radius:10px;font-weight:600;font-size:13px;opacity:0;transition:.2s;pointer-events:none;z-index:60}
  .toast.on{opacity:1}
  .empty{color:var(--mut);text-align:center;padding:60px 0}
</style>
</head>
<body>
<div class="wrap">
  <div class="brand"><svg viewBox="0 0 40 40" width="34" height="34" style="vertical-align:middle;margin-right:9px"><defs><linearGradient id="snl" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#6c8cff"/><stop offset="1" stop-color="#1ed7a0"/></linearGradient></defs><rect width="40" height="40" rx="11" fill="#101726" stroke="#222a3a"/><path d="M6 30 L15 24 L22 26 L34 12" fill="none" stroke="url(#snl)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="28" r="1.7" fill="#1ed7a0"/><circle cx="18" cy="25" r="1.7" fill="#1ed7a0"/><circle cx="27" cy="19" r="1.7" fill="#6c8cff"/><g stroke="#cfe0ff" stroke-width="1.2" stroke-linecap="round"><line x1="33" y1="6.5" x2="33" y2="15"/><line x1="28.8" y1="10.7" x2="37.2" y2="10.7"/><line x1="30.1" y1="7.8" x2="35.9" y2="13.6"/><line x1="35.9" y1="7.8" x2="30.1" y2="13.6"/></g></svg>Snov<span>tracker</span></div>
  <div class="tag">❄ Sek geriausius Solana blue-chip (SOL · ETH · BTC) treiderius. Realūs skaičiai, po visų mokesčių.</div>
  <div id="stats" class="statbar"></div>
  <div class="controls">
    <span id="pills"></span>
    <span class="spacer"></span>
    <select id="sort" onchange="render()">
      <option value="copyScore">Pagal balą</option>
      <option value="returnPct">Pagal grąžą %</option>
      <option value="roiPct">Pagal pelną $</option>
      <option value="winRatePct">Pagal win %</option>
    </select>
  </div>
  <div id="rows" class="rows"><div class="empty">Kraunama…</div></div>
  <button id="moreBtn" class="more" style="display:none" onclick="LIMIT+=10;render()">Rodyti daugiau</button>
  <div id="meta" class="mut" style="text-align:center;margin-top:24px;font-size:12px"></div>
</div>

<div class="ov" id="ov" onclick="if(event.target===this)closeM()"><div class="modal" id="modal"></div></div>
<div class="toast" id="toast">✓</div>

<script>
var DATA=null, ASSET="Visi", LIMIT=10;
var CUR=null, MAMT=1000, MTF="30", MPAGE=0, PAGE=8, CHARTPTS=[];
var ASSETS=["Visi","SOL","ETH","BTC"];
var ACT={open:"Atidarė",add:"Padidino",addMargin:"Pridėjo maržą",reduce:"Sumažino",close:"Uždarė"};
var $=function(id){return document.getElementById(id);};
var money=function(n){var v=Math.round((n||0));return (v<0?"-$":"$")+Math.abs(v).toLocaleString("en-US");};
var pct=function(n){return (n>=0?"+":"")+(Math.round((n||0)*10)/10)+"%";};
function toast(t){var e=$("toast");e.textContent=t;e.classList.add("on");setTimeout(function(){e.classList.remove("on");},1100);}
function fallbackCopy(w){try{var ta=document.createElement("textarea");ta.value=w;ta.style.position="fixed";ta.style.top="-9999px";document.body.appendChild(ta);ta.focus();ta.select();var ok=document.execCommand("copy");document.body.removeChild(ta);return ok;}catch(e){return false;}}
function copyW(w){
  if(navigator.clipboard&&navigator.clipboard.writeText){ navigator.clipboard.writeText(w).then(function(){toast("✓ adresas nukopijuotas");}).catch(function(){toast(fallbackCopy(w)?"✓ adresas nukopijuotas":"Nepavyko kopijuoti");}); }
  else { toast(fallbackCopy(w)?"✓ adresas nukopijuotas":"Nepavyko kopijuoti"); }
}
function ago(ts){if(!ts)return"—";var d=(Date.now()/1000-ts)/86400;if(d<1)return"šiandien";return"prieš "+Math.floor(d)+" d.";}
function actCls(ts){if(!ts)return"mut";var d=(Date.now()/1000-ts)/86400;return d<=14?"pos":(d<=45?"":"mut");}

function spark(curve,col,W,H){
  W=W||120;H=H||36;
  if(!curve||curve.length<2) return '<svg class="spark" viewBox="0 0 '+W+' '+H+'"></svg>';
  var v=curve.map(function(c){return c.bankroll;});
  var mn=Math.min.apply(null,v),mx=Math.max.apply(null,v),n=v.length;
  var d=v.map(function(p,i){return (i?"L":"M")+(i*W/(n-1)).toFixed(1)+" "+(H-2-(p-mn)/(mx-mn||1)*(H-4)).toFixed(1);}).join(" ");
  var area=d+" L"+W+" "+H+" L0 "+H+" Z";
  var gid="g"+Math.random().toString(36).slice(2,7);
  return '<svg class="spark" viewBox="0 0 '+W+' '+H+'" preserveAspectRatio="none"><defs><linearGradient id="'+gid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="'+col+'" stop-opacity=".25"/><stop offset="1" stop-color="'+col+'" stop-opacity="0"/></linearGradient></defs><path d="'+area+'" fill="url(#'+gid+')"/><path d="'+d+'" fill="none" stroke="'+col+'" stroke-width="2"/></svg>';
}

function pills(){$("pills").innerHTML=ASSETS.map(function(a){return '<span class="pill'+(a===ASSET?" on":"")+'" onclick="ASSET=\''+a+'\';LIMIT=10;render()">'+a+'</span>';}).join(" ");}
function eligible(){
  if(!DATA||!DATA.ranking)return[];
  var rows=DATA.ranking.filter(function(r){return (r.roiPct||0)>0;}); // pelningi
  if(ASSET!=="Visi") rows=rows.filter(function(r){return (r.assets||"").indexOf(ASSET)>=0;});
  var k=$("sort").value; rows.sort(function(a,b){return (b[k]||0)-(a[k]||0);});
  return rows;
}
function stats(){
  var all=(DATA&&DATA.ranking)||[];
  var plus=all.filter(function(r){return (r.roiPct||0)>0;}).length;
  var minus=all.filter(function(r){return (r.roiPct||0)<0;}).length;
  var sc=function(n,l,cls){return '<div class="sc"><div class="n'+(cls?" "+cls:"")+'">'+n+'</div><div class="l">'+l+'</div></div>';};
  $("stats").innerHTML=sc(all.length,"Treiderių")+sc(plus,"Pelninguose","pos")+sc(minus,"Minuse","neg");
}
function render(){
  pills(); stats();
  var rows=eligible();
  if(!rows.length){$("rows").innerHTML='<div class="empty">Nėra treiderių pagal šį filtrą.</div>';$("moreBtn").style.display="none";$("meta").textContent="";return;}
  $("rows").innerHTML=rows.slice(0,LIMIT).map(function(r,i){
    var col=(r.returnPct||0)>=0?"#1ed7a0":"#f0556b";
    return '<div class="row'+(i===0?" top1":"")+'" onclick="openM(\''+r.wallet+'\')">'+
      '<div class="rk">'+(i+1)+'</div>'+
      '<div class="who"><div class="nm addr">'+r.wallet.slice(0,4)+'…'+r.wallet.slice(-4)+'<span class="asset">'+(r.assets||"").split("/")[0]+'</span></div>'+
        '<div class="sub">'+(r.profile?'<b style="color:var(--text)">'+r.profile+'</b> · ':'')+'aktyvus <span class="'+actCls(r.lastTs)+'">'+ago(r.lastTs)+'</span> · live '+(r.daysLive!=null?r.daysLive:0)+' d.</div></div>'+
      spark(r.curve,col)+
      '<div class="mini"><div><div class="l">Win</div><div class="v">'+(r.winRatePct||0)+'%</div></div><div><div class="l">Svertas</div><div class="v">'+(r.avgLev||0)+'x</div></div></div>'+
      '<div><div class="ret '+((r.returnPct||0)>=0?"pos":"neg")+'">'+pct(r.returnPct)+'</div><div class="pnl">pelnas '+money(r.roiPct)+'</div></div>'+
    '</div>';
  }).join("");
  $("moreBtn").style.display=(rows.length>LIMIT)?"block":"none";
  $("meta").innerHTML=(DATA.generatedAt?"Atnaujinta "+DATA.generatedAt.replace("T"," ").slice(0,16)+" · ":"")+rows.length+" treiderių · skaičiai po visų mokesčių";
}

function tfReturn(r){ // grąža iš forward $1000 kreivės pasirinktame laikotarpyje
  var c=tfCurve(r); if(!c||c.length<2) return r.fwdReturnPct||0;
  return (c[c.length-1].bankroll/c[0].bankroll-1)*100;
}
function tfCurve(r){
  var c=r.fwdCurve||r.curve||[]; if(MTF==="all"||c.length<2) return c;
  var days=parseInt(MTF), cut=Date.now()/1000-days*86400;
  var f=c.filter(function(p){return p.ts>=cut;});
  return f.length>=2?f:c;
}
var HCACHE={}, HLOADING={};
var ASSETN={"So11111111111111111111111111111111111111112":"SOL","3NZ9JMVBmGAqocybic2c7LQCJScmgsAZ6vQqTDzcqmJh":"BTC","7vfCXTUXx5WJV5JADk17DUJ4ksgau7utNKj4b963voxs":"ETH"};
var Nn=function(x){var n=Number(x);return isFinite(n)?n:0;};
function labelHistory(ev){ // ev: asc; priskiriam veiksmus pagal likuti
  var rem={}, out=[];
  ev.forEach(function(e){
    var label;
    if(e.action==="Increase"){var had=rem[e.pk]>1;rem[e.pk]=(rem[e.pk]||0)+e.size;label=e.size<=0?"addMargin":(had?"add":"open");}
    else{rem[e.pk]=(rem[e.pk]||0)-e.size;label=rem[e.pk]<=1?"close":"reduce";}
    var cAbs=Math.abs(e.coll||0);
    out.push({ts:e.ts,asset:e.asset,action:label,side:e.side,priceUsd:Math.round(e.price*100)/100,sizeUsd:Math.round(e.size),collUsd:Math.round(cAbs),lev:(e.action==="Increase"&&cAbs>0&&e.size>0?Math.round(e.size/cAbs*100)/100:null),pnlUsd:e.pnl!=null?Math.round((e.pnl-e.fee)*100)/100:null});
  });
  return out.reverse(); // naujausi virsuje
}
async function fetchFullHistory(w){
  if(HLOADING[w])return; HLOADING[w]=true;
  try{
    // 1) musu serveris (greita, is failo)
    var sr=await fetch("/api/history?wallet="+w,{cache:"no-store"});
    if(sr.ok){ var h=await sr.json(); if(Array.isArray(h)){ HCACHE[w]=h; throw "done"; } }
    // 2) fallback: tiesiai is Jupiter
    var all=[],start=0,count=0;
    for(var p=0;p<40;p++){
      var r=await fetch("https://perps-api.jup.ag/v2/trades?walletAddress="+w+"&start="+start+"&end="+(start+500));
      if(!r.ok)break; var j=await r.json(); count=j.count||count; var list=j.dataList||[]; if(!list.length)break;
      all=all.concat(list); start+=list.length; if(all.length>=count)break;
    }
    var ev=all.map(function(t){var ts=Nn(t.createdTime);if(ts>1e12)ts=Math.floor(ts/1000);
      return {ts:ts,pk:t.positionPubkey,asset:ASSETN[t.mint]||"?",action:t.action,side:t.side,size:Nn(t.size),coll:Math.abs(Nn(t.collateralUsdDelta)),price:Nn(t.price),fee:Nn(t.fee)+Nn(t.borrowFee),pnl:t.pnl!=null?Nn(t.pnl):null};
    }).sort(function(a,b){return a.ts-b.ts;});
    HCACHE[w]=labelHistory(ev);
  }catch(e){ if(e!=="done"&&!HCACHE[w]) HCACHE[w]=null; }
  HLOADING[w]=false;
  if(CUR&&CUR.wallet===w&&$("ov").classList.contains("on")) detail();
}
function setAmt(v){ MAMT=Math.max(1,Math.round(v||0)); detail(); }
function setTf(t){ MTF=t; detail(); }
function setPage(p){ MPAGE=p; detail(); }
function openM(w){ CUR=DATA.ranking.find(function(x){return x.wallet===w;}); if(!CUR)return; MPAGE=0; detail(); $("ov").classList.add("on"); $("ov").scrollTop=0; if(!HCACHE[w]) fetchFullHistory(w); }
function closeM(){$("ov").classList.remove("on");}

function detail(){
  var r=CUR; if(!r)return;
  var col=(r.returnPct||0)>=0?"#1ed7a0":"#f0556b";
  var hist=HCACHE[r.wallet]||r.history||[];  // tikri jo sandoriai (naujausi virsuje)
  var loadingH=HLOADING[r.wallet]&&!HCACHE[r.wallet];
  // reali kreive: kaupiamasis neto pelnas per visa istorija
  var rc=[], cum=0;
  hist.slice().reverse().forEach(function(e){ if(e.pnlUsd!=null){ cum+=e.pnlUsd; rc.push({ts:e.ts,bankroll:Math.round(cum*100)/100}); } });
  // istorija puslapiais
  var H=hist, pages=Math.max(1,Math.ceil(H.length/PAGE)), pg=Math.min(MPAGE,pages-1);
  var slice=H.slice(pg*PAGE,pg*PAGE+PAGE).map(function(e){
    var d=e.ts?new Date(e.ts*1000).toISOString().slice(0,16).replace("T"," "):"";
    var pnl=e.pnlUsd==null?'<span class="mut">—</span>':'<span class="'+(e.pnlUsd>=0?"pos":"neg")+'">'+money(e.pnlUsd)+'</span>';
    var sideB='<span class="'+(e.side==="long"?"pos":"neg")+'" style="font-weight:700">'+(e.side==="long"?"LONG":"SHORT")+'</span>';
    var levTxt = e.lev!=null ? (e.lev+"x") : '<span class="mut">—</span>';
    var collTxt = e.collUsd!=null ? money(e.collUsd) : '<span class="mut">—</span>';
    return '<tr><td>'+d+'</td><td>'+e.asset+'</td><td>'+sideB+' <span class="mut">'+(ACT[e.action]||e.action)+'</span></td><td>$'+(e.priceUsd||0)+'</td><td>'+money(e.sizeUsd)+'</td><td>'+collTxt+'</td><td>'+levTxt+'</td><td>'+pnl+'</td></tr>';
  }).join("");
  $("modal").innerHTML='<span class="x" onclick="closeM()">✕</span>'+
    '<div class="addr" style="font-size:14px"><span onclick="copyW(\''+r.wallet+'\')" style="cursor:pointer" title="kopijuoti">'+r.wallet.slice(0,8)+'…'+r.wallet.slice(-6)+'</span> <span class="asset">'+(r.assets||"")+'</span></div>'+
    '<div style="display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-top:12px">'+
      '<div class="ret '+((r.returnPct||0)>=0?"pos":"neg")+'" style="font-size:32px">'+pct(r.returnPct)+'</div>'+
      '<div class="mut">grąža · pelnas <b style="color:var(--text)">'+money(r.roiPct)+'</b> · live '+(r.daysLive!=null?r.daysLive:0)+' d.</div>'+
    '</div>'+
    '<div class="kpis" style="margin-top:12px">'+
      '<div class="kpi"><div class="l">Profilis</div><div class="v">'+(r.profile||"—")+'</div></div>'+
      '<div class="kpi"><div class="l">Win</div><div class="v">'+(r.winRatePct||0)+'%</div></div>'+
      '<div class="kpi"><div class="l">Sandorių</div><div class="v">'+(r.closed||0)+'</div></div>'+
      '<div class="kpi"><div class="l">Sand./d</div><div class="v">'+(r.tradesPerActiveDay!=null?r.tradesPerActiveDay:r.tradesPerDay||0)+'</div></div>'+
      '<div class="kpi"><div class="l">Laikymas</div><div class="v">'+(r.avgHoldH!=null?r.avgHoldH+"h":"—")+'</div></div>'+
      '<div class="kpi"><div class="l">Svertas</div><div class="v">'+(r.avgLev||0)+'x</div></div>'+
      '<div class="kpi"><div class="l">Kapitalas</div><div class="v">'+money(r.peakUsd||0)+'</div></div>'+
      '<div class="kpi"><div class="l">Aktyvus</div><div class="v '+actCls(r.lastTs)+'">'+ago(r.lastTs)+'</div></div>'+
    '</div>'+
    '<h3 style="margin-top:18px">Pelno kreivė (viso laiko)</h3>'+
    '<div id="chartWrap" style="position:relative;height:240px;background:var(--card2);border:1px solid var(--line);border-radius:12px"></div>'+
    '<div style="display:flex;gap:10px;margin-top:16px">'+
      '<button class="cta" style="flex:1" onclick="location.href=\'paper.html?wallet='+r.wallet+'\'">▶ Demo kopijuoti</button>'+
      '<button class="cta sec" style="flex:1" onclick="realCopy(\''+r.wallet+'\')">Kopijuoti tikrais</button>'+
    '</div>'+
    '<h3>Pirko / pardavė '+(loadingH?'<span class="mut">(kraunama…)</span>':'')+'</h3>'+
    '<div style="overflow:auto"><table><thead><tr><th>Laikas</th><th>Turtas</th><th>Veiksmas</th><th>Kaina</th><th>Dydis</th><th>Pinigai</th><th>Svertas</th><th>PnL</th></tr></thead><tbody>'+(slice||'<tr><td colspan="8" class="mut">'+(loadingH?'kraunama…':'Nėra sandorių.')+'</td></tr>')+'</tbody></table></div>'+
    '<div style="display:flex;align-items:center;gap:12px;margin-top:10px;justify-content:center">'+
      '<button class="pgbtn" onclick="setPage('+(pg-1)+')" '+(pg<=0?"disabled":"")+'>‹ ankstesni</button>'+
      '<span class="mut" style="font-size:12px">'+(pg+1)+' / '+pages+'</span>'+
      '<button class="pgbtn" onclick="setPage('+(pg+1)+')" '+(pg>=pages-1?"disabled":"")+'>vėlesni ›</button>'+
    '</div>';
  buildChart(rc, col);
}
var dstr=function(ts){return ts?new Date(ts*1000).toISOString().slice(0,10):"";};
function buildChart(curve,col){
  var wrap=$("chartWrap"); if(!wrap)return;
  if(!curve||curve.length<2){wrap.innerHTML='<div class="mut" style="padding:40px;text-align:center">Nepakanka duomenų grafikui.</div>';CHARTPTS=[];return;}
  var W=wrap.clientWidth||760, H=250, padL=8, padR=8, padT=14, padB=22;
  var v=curve.map(function(c){return c.bankroll;});
  var mn=Math.min.apply(null,v), mx=Math.max.apply(null,v), n=v.length;
  var X=function(i){return padL+i*(W-padL-padR)/(n-1);};
  var Y=function(val){return H-padB-(mx===mn?0.5:(val-mn)/(mx-mn))*(H-padT-padB);};
  CHARTPTS=curve.map(function(c,i){return {x:X(i),y:Y(c.bankroll),ts:c.ts,val:c.bankroll,step:i?c.bankroll-curve[i-1].bankroll:0};});
  var line=CHARTPTS.map(function(p,i){return (i?"L":"M")+p.x.toFixed(1)+" "+p.y.toFixed(1);}).join(" ");
  var area=line+" L"+X(n-1).toFixed(1)+" "+(H-padB)+" L"+X(0).toFixed(1)+" "+(H-padB)+" Z";
  var dots=CHARTPTS.map(function(p){return '<circle cx="'+p.x.toFixed(1)+'" cy="'+p.y.toFixed(1)+'" r="2.5" fill="'+(p.step>=0?"#1ed7a0":"#f0556b")+'"/>';}).join("");
  var d0=dstr(curve[0].ts), d1=dstr(curve[n-1].ts);
  wrap.innerHTML='<svg width="'+W+'" height="'+H+'" viewBox="0 0 '+W+' '+H+'" style="display:block">'+
    '<defs><linearGradient id="eqg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="'+col+'" stop-opacity=".22"/><stop offset="1" stop-color="'+col+'" stop-opacity="0"/></linearGradient></defs>'+
    '<path d="'+area+'" fill="url(#eqg)"/><path d="'+line+'" fill="none" stroke="'+col+'" stroke-width="2"/>'+dots+
    '<text x="'+padL+'" y="'+(H-6)+'" fill="#7e89a0" font-size="11">'+d0+'</text>'+
    '<text x="'+(W-padR)+'" y="'+(H-6)+'" fill="#7e89a0" font-size="11" text-anchor="end">'+d1+'</text>'+
    '<text x="'+(padL+4)+'" y="'+(padT+4)+'" fill="#7e89a0" font-size="11">'+money(mx)+'</text></svg>'+
    '<div id="chCross" style="position:absolute;top:0;height:'+(H-padB)+'px;width:1px;background:var(--line2);display:none;pointer-events:none"></div>'+
    '<div id="chDot" style="position:absolute;width:9px;height:9px;border-radius:50%;background:#fff;border:2px solid '+col+';transform:translate(-50%,-50%);display:none;pointer-events:none"></div>'+
    '<div id="chTip" style="position:absolute;background:#0c111b;border:1px solid var(--line2);border-radius:8px;padding:6px 10px;font-size:12px;pointer-events:none;display:none;white-space:nowrap;transform:translate(-50%,-130%);z-index:5"></div>';
  wrap.onmousemove=chartHover; wrap.onmouseleave=chartLeave;
}
function chartHover(e){
  if(!CHARTPTS.length)return;
  var wrap=$("chartWrap"), rect=wrap.getBoundingClientRect(), x=e.clientX-rect.left;
  var best=CHARTPTS[0],bd=1e9; CHARTPTS.forEach(function(p){var d=Math.abs(p.x-x);if(d<bd){bd=d;best=p;}});
  var cr=$("chCross"),dt=$("chDot"),tp=$("chTip");
  cr.style.display="block";cr.style.left=best.x+"px";
  dt.style.display="block";dt.style.left=best.x+"px";dt.style.top=best.y+"px";
  tp.style.display="block";tp.style.left=Math.min(Math.max(best.x,70),rect.width-70)+"px";tp.style.top=best.y+"px";
  tp.innerHTML='<b>'+money(best.val)+'</b> <span class="'+(best.step>=0?"pos":"neg")+'">'+(best.step>=0?"+":"")+money(best.step)+'</span><br><span class="mut">'+dstr(best.ts)+'</span>';
}
function chartLeave(){var c=$("chCross"),d=$("chDot"),t=$("chTip");if(c)c.style.display="none";if(d)d.style.display="none";if(t)t.style.display="none";}
function realCopy(w,amt){ alert("Tikras kopijavimas su "+money(amt)+": reikės prijungti Solana piniginę (non-custodial — tu pats pasirašai). Ši dalis ruošiama.\\n\\nKol kas išbandyk Demo — ta pati logika, be rizikos."); }
document.addEventListener("keydown",function(e){if(e.key==="Escape")closeM();});
function loadData(){ return fetch("ranking.json",{cache:"no-store"}).then(function(r){ if(!r.ok) throw new Error("http "+r.status); return r.json(); }).then(function(j){DATA=j; if(!$("ov").classList.contains("on")) render(); }).catch(function(){ if(!DATA){ $("rows").innerHTML='<div class="empty">Kraunama… <span class="mut" style="font-size:12px">(bandom dar kartą)</span></div>'; setTimeout(loadData, 4000); } }); }
loadData();
setInterval(loadData, 120000);
</script>
